{
  "name": "healthcare-crm",
  "version": "1.0.0",
  "description": "Healthcare CRM - Patient Notes Management",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "start": "npm run dev:frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run offline --prefix backend",
    "test": "npm test --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
